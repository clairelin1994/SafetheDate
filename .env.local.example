# PostgreSQL connection string
# Example using Neon: postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/safe_of_the_date

# Resend API key — get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Secret for signing JWT tokens — use a long random string
JWT_SECRET=your-very-long-and-random-secret-key-here

# Secret for protecting the cron endpoint (Vercel sets this automatically in production)
CRON_SECRET=your-cron-secret-here

# The domain used in emails (optional, defaults to example.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
